{
  "manifest_version": 3,
  "name": "AI Web Editor",
  "version": "2.1.0",
   "description": "AI-powered web page editor: modify any element's content, style, or layout using natural language commands.",
   "privacy_policy_url": "https://github.com/hanchenglong001/AI_Web_Editor/blob/main/privacy-policy.html",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://*.openai.com https://api.openai.com https://generativelanguage.googleapis.com https://dashscope.aliyuncs.com https://558c142bee5e4d9080d9d29f0bee9ce7.hanclong.eu.org http://localhost:* http://127.0.0.1:*; img-src 'self' data: blob:;"
  },
  "commands": {
    "toggle-editor": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Cmd+Shift+E"
      },
      "description": "Toggle AI Web Editor panel"
    }
  }
}